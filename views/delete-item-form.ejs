<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <!-- Page header -->
    <header class="inventory-header">
      <h1 class="inventory-header__header" >Computer Inventory Form</h1>
    </header>

    <!-- Page main content -->
    <main>
      <div class="form-container__div">
        <form class="form-container__form">
          <h2>Delete Item Form</h2>

          <div class="form-container__form-group-div">
            <label for="id">Id:</label>
            <input type="number" name="id" id="id" min="1" max="999" required>
          </div>

          <div class="form-container__form-group-div">
            <label for="password">Password:</label>
            <input type="text" name="password" id="password" placeholder="123..." minlength="1" maxlength="20" required>
          </div>

          <button type="submit" class="form-container__submit-button">Delete</button>

        </form>
      </div>
    </main>

    <!-- Page Footer -->
     <footer>

     </footer>
  </body>
</html>