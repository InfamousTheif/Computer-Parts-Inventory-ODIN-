<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <!-- Page header -->
    <header class="inventory-header">
      <h1 class="inventory-header__header" >Computer Inventory Form</h1>
    </header>

    <!-- Page main content -->
    <main>
      <div class="form-container__div delete-form-container__div">
        <form method="POST" action="/deleteItem?Id=<%=Id%>" class="form-container__form">
          <h2>Delete Item Form</h2>
          <div class="form-container__form-group-div">
            <label for="password">Password:</label>
            <input type="password" name="password" id="password" placeholder="pass123..." minlength="1" maxlength="20" required>
          </div>

          <button type="submit" class="form-container__submit-button">Delete</button>

        </form>
      </div>
    </main>

    <!-- Page Footer -->
     <footer>

     </footer>
  </body>
</html>